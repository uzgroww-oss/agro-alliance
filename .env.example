# =============================================================================
# Agro Alliance — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your production values.
# Never commit .env to version control.
# =============================================================================

# ----- Supabase -----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----- Supabase Auth -----
# Used by auth-login Edge Function
SUPABASE_AUTH_SMTP_HOST=smtp.sendgrid.net
SUPABASE_AUTH_SMTP_PORT=587
SUPABASE_AUTH_SMTP_USER=apikey
SUPABASE_AUTH_SMTP_PASS=your-sendgrid-api-key
SUPABASE_AUTH_SMTP_ADMIN_EMAIL=admin@agroalliance.uz
SUPABASE_AUTH_SMTP_SENDER_NAME="Agro Alliance"

# ----- OAuth Providers -----
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-google-client-secret
SUPABASE_AUTH_EXTERNAL_TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ----- Cloudflare R2 -----
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=agro-alliance-media
R2_PUBLIC_URL=https://media.agroalliance.uz
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# ----- Cloudflare Workers AI -----
CF_AI_API_TOKEN=your-cloudflare-ai-api-token
CF_ACCOUNT_ID=your-cloudflare-account-id

# ----- YouTube Data API -----
YOUTUBE_API_KEY=your-youtube-api-key

# ----- Telegram Bot -----
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHANNEL_ID=@your_channel_username

# ----- Platform URLs -----
PUBLIC_SITE_URL=https://agroalliance.uz
PUBLIC_API_URL=https://api.agroalliance.uz
